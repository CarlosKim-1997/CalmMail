# CalmMail environment variables (development / distributor packaging).
# Never commit real secrets. Copy to `.env` locally.

# --- Gmail / Google OAuth ---
# Create OAuth credentials of type "Desktop app" in Google Cloud Console
# and enable the Gmail API for that project. Loopback redirect is used.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Local AI model downloads (optional) ---
# Only needed for Hugging Face repos that return HTTP 401 without a token.
# Public catalog mirrors usually work without this.
# HF_TOKEN=

# --- Cloud AI (optional; bundled with build — NOT entered in the app UI) ---
# End users are not asked for API keys. For dev or a distributor build, set
# one of these so "Cloud AI" shows as available for that provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Monetization (dev / QA) ---
# When set to 1, treats the app as Premium (no sponsor slots, lower poll floor).
# CALMMAIL_DEV_PREMIUM=1
# Optional URL opened by "Learn about Premium" in Settings.
# CALMMAIL_PREMIUM_INFO_URL=https://example.com/premium
# In-app billing stub: Plans screen shows "Activate Premium (stub)" without Stripe.
# CALMMAIL_BILLING_STUB=1
# External checkout page (Stripe Payment Link, etc.). Used when STRIPE_* keys are absent.
# CALMMAIL_CHECKOUT_URL=https://example.com/checkout
#
# --- Stripe API (operator .env — creates Checkout Sessions in-app) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID_PREMIUM=price_...
# After checkout, Stripe redirects to calmmail://billing/success?session_id=...
#
# Optional: local webhook for `stripe listen --forward-to localhost:4242/stripe/webhook`
# STRIPE_WEBHOOK_SECRET=whsec_...
# CALMMAIL_STRIPE_WEBHOOK_PORT=4242
